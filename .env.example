# ============== Фронт (сборка Vite) — все URL только HTTPS в production ==============
# Задайте при сборке (npm run build). Без http:// — иначе браузер покажет "Not secure" (Mixed Content).

# Базовый URL сайта (canonical, Open Graph). Без слэша в конце.
VITE_SITE_URL=https://ion-studio.ru

# URL бэкенда для формы обратной связи (без слэша в конце). Только HTTPS в production.
VITE_API_BASE_URL=https://ion-studio.ru/api

# Альтернатива: если бэкенда нет, используйте Formspree (все URL уже HTTPS).
# VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/xxxxxxxx
# VITE_CHAT_FORM_ENDPOINT=https://formspree.io/f/yyyyyyyy

# Локальная разработка: в .env можно указать http://localhost:4000 для VITE_API_BASE_URL.

# ============== Бэкенд (если свой API на Node и т.п.) ==============
# FRONTEND_ORIGIN=https://ion-studio.ru
# EMAIL_USER=...
# EMAIL_PASS=...
# PORT=4000
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
